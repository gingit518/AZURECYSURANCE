<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
		xmlns="http://www.ehcache.org/v3"
		xmlns:jsr107="http://www.ehcache.org/v3/jsr107"
		xsi:schemaLocation="
            http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core-3.0.xsd
            http://www.ehcache.org/v3/jsr107 http://www.ehcache.org/schema/ehcache-107-ext-3.0.xsd">


	<cache alias="OTP_CODES">
		<key-type>java.lang.String</key-type>
		<value-type>com.cyberintech.vrisk.server.security.mfa.MFACodeTokenDTO</value-type>
		<expiry>
			<ttl unit="seconds">300</ttl>
		</expiry>

		<!--
		<listeners>
			<listener>
				<class>com.baeldung.cachetest.config.CacheEventLogger</class>
				<event-firing-mode>ASYNCHRONOUS</event-firing-mode>
				<event-ordering-mode>UNORDERED</event-ordering-mode>
				<events-to-fire-on>CREATED</events-to-fire-on>
				<events-to-fire-on>EXPIRED</events-to-fire-on>
			</listener>
		</listeners>
		-->

		<resources>
			<heap unit="entries">50000</heap>
			<offheap unit="MB">10</offheap>
		</resources>
	</cache>

	<cache alias="DASHBOARD_SEARCH">
		<key-type>java.lang.String</key-type>
		<value-type>java.lang.String</value-type>
		<expiry>
			<ttl unit="seconds">36000</ttl>
		</expiry>
		<resources>
			<heap unit="entries">50000</heap>
			<offheap unit="MB">100</offheap>
		</resources>
	</cache>

	<cache alias="DOWNLOAD_LINK">
		<key-type>java.lang.String</key-type>
		<value-type>java.lang.String</value-type>
		<expiry>
			<ttl unit="seconds">36000</ttl>
		</expiry>
		<resources>
			<heap unit="entries">50000</heap>
			<offheap unit="MB">100</offheap>
		</resources>
	</cache>

	<!-- Zoom Info Caching Segment -->
	<cache alias="ZOOM_INFO">
		<key-type>java.lang.Long</key-type>
		<value-type>com.cyberintech.vrisk.server.service.integrations.marketing.zoominfo.dto.OrganizationZoomInfoExtendedDetails</value-type>
		<expiry>
			<ttl unit="seconds">86400</ttl>
		</expiry>
		<resources>
			<heap unit="entries">100</heap>
			<offheap unit="MB">100</offheap>
		</resources>
	</cache>

	<cache alias="AUTHORIZATIONS">
		<key-type>java.lang.String</key-type>
		<value-type>java.lang.String</value-type>
		<expiry>
			<ttl unit="seconds">3000</ttl>
		</expiry>
		<resources>
			<heap unit="entries">500</heap>
			<offheap unit="MB">10</offheap>
		</resources>
	</cache>

</config>
